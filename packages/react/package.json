{
  "name": "@diffcp/react",
  "version": "0.0.0",
  "description": "React integration of diffcp the open-source standard for connecting AI user interfaces to backend systems",
  "author": {
    "name": "Axelered AI",
    "email": "dev@axelered.com",
    "url": "https://axelered.com/"
  },
  "contributors": [
    {
      "name": "Borut Svara",
      "email": "borut@axelered.com",
      "url": "https://svara.io/"
    }
  ],
  "keywords": [
    "ai",
    "protocol",
    "axelered",
    "react"
  ],
  "homepage": "https://github.com/axelered/diffcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/axelered/diffcp.git"
  },
  "bugs": {
    "url": "https://github.com/axelered/diffcp/issues",
    "email": "dev@axelered.com"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@diffcp/core": "packages/core:^"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
